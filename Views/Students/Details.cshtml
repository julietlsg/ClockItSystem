@model ClockItSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">
    <h2>Student Details</h2>

    <div class="clockit-card">
        <div class="row">
            <div class="col-md-3">
                @if (!string.IsNullOrEmpty(Model.FaceImagePath))
                {
                    <img src="@Model.FaceImagePath" width="180" height="180" style="border-radius:16px; object-fit:cover;" />
                }
                else
                {
                    <p>No image uploaded.</p>
                }
            </div>

            <div class="col-md-9">
                <dl class="row">
                    <dt class="col-sm-4">Student Number</dt>
                    <dd class="col-sm-8">@Model.StudentNumber</dd>

                    <dt class="col-sm-4">ID Number</dt>
                    <dd class="col-sm-8">@Model.IdNumber</dd>

                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                    <dt class="col-sm-4">Programme/Course</dt>
                    <dd class="col-sm-8">@Model.ProgrammeOrCourse</dd>

                    <dt class="col-sm-4">Contact Number</dt>
                    <dd class="col-sm-8">@Model.ContactNumber</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge status-approved">Active</span>
                        }
                        else
                        {
                            <span class="badge status-rejected">Inactive</span>
                        }
                    </dd>
                </dl>

                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-clockit">Edit</a>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
                <a asp-controller="Biometric" asp-action="Enroll" asp-route-studentId="@Model.Id" class="btn btn-clockit"> Enrol Face </a>
            </div>
        </div>
    </div>
</div>