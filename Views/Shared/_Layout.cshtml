<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Clock It</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/clockit-theme.css" asp-append-version="true" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-clockit">

        <div class="container-fluid">

            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                Clock It
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

<ul class="navbar-nav ms-auto">

    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Home"
           asp-action="Index">
            Home
        </a>
    </li>
                    <li class="nav-item">
                        <a class="nav-link"
                               asp-controller="Biometric"
                               asp-action="Verify">
                            Facial Verification
                        </a>
                    </li>


    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Students"
                   asp-action="Index">
                    Students
                </a>
            </li>

@*             <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Biometric"
                   asp-action="Verify">
                    Facial Verification
                </a>
            </li>
 *@        }

        @if (User.IsInRole("Facilitator"))
        {
@*             <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Biometric"
                   asp-action="Verify">
                    Facial Verification
                </a>
            </li>
 *@        }

        @if (User.IsInRole("Admin") || User.IsInRole("Facilitator"))
        {
@*             <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Approvals"
                   asp-action="Daily">
                    Approvals
                </a>
            </li>
 *@
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle"
                   href="#"
                   id="reportsDropdown"
                   role="button"
                   data-bs-toggle="dropdown"
                   aria-expanded="false">
                    Reports
                </a>

                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="reportsDropdown">
                    <li>
                        <a class="dropdown-item"
                           asp-controller="Reports"
                           asp-action="OfficialAttendance">
                            Official Attendance
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           asp-controller="Reports"
                           asp-action="PendingApprovals">
                            Pending Approvals
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           asp-controller="Reports"
                           asp-action="RejectedAttendance">
                            Rejected Attendance
                        </a>
                    </li>
                </ul>
            </li>
        }

        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Account"
                   asp-action="Register">
                    Register User
                </a>
            </li>
        }

        <li class="nav-item">
            <form asp-controller="Account"
                  asp-action="Logout"
                  method="post"
                  class="d-inline">
                @Html.AntiForgeryToken()

                <button type="submit"
                        class="btn btn-link nav-link text-light">
                    Logout
                </button>
            </form>
        </li>
    }

</ul>            </div>

        </div>

    </nav>

    <main role="main">

        @RenderBody()

    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>