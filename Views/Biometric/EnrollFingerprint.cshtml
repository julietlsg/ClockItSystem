@{
    ViewData["Title"] = "Fingerprint Enrollment";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-success text-white">
            <h3>Fingerprint Enrollment</h3>
        </div>

        <div class="card-body">

            <h5>
                @ViewBag.StudentName
            </h5>

            <hr />

            <div id="statusMessage"
                 class="alert alert-info">

                Ready to capture fingerprint.
            </div>

            <div class="text-center">

                <button id="captureBtn"
                        class="btn btn-success btn-lg">

                    Capture Fingerprint
                </button>

            </div>

            <input type="hidden"
                   id="studentId"
                   value="@ViewBag.StudentId" />

        </div>

    </div>

</div>

@section Scripts
{
    <script src="~/js/fingerprint-enrollment.js"></script>
}