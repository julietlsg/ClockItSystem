@{
    ViewData["Title"] = "Fingerprint Enrollment";
    var studentId = ViewBag.StudentId;
}

<div class="container mt-4">

    <div class="clockit-card">

        <div>
            <h3>Fingerprint Enrollment</h3>
        </div>

        <div class="card-body">

            <h5>
                @ViewBag.StudentName
            </h5>

            <hr />

            <div id="statusMessage"
                 class="alert alert-info">

                Ready to capture fingerprint.
            </div>

            <div class="text-center">

                <button id="captureBtn"
                        class="btn btn-primary">

                    Capture Fingerprint
                </button>

                <a asp-controller="Biometric"
                       asp-action="Index"
                       asp-route-studentId="@studentId"
                       class="btn btn-secondary">
                    Cancel
                </a>

            </div>

            <input type="hidden"
                   id="studentId"
                   value="@ViewBag.StudentId" />
        </div>

    </div>

</div>

@section Scripts
{
    <script src="~/js/fingerprint-enrollment.js"></script>
}