@{
    ViewData["Title"] = "Facial Verification";
}

<div class="biometric-page">

    <div class="biometric-card">

        <h2>Facial Attendance Verification</h2>

        <p class="biometric-instruction">
            Place the student's face within the scan area. Attendance will be recorded automatically.
        </p>

        <div class="face-scan-wrapper">

            <div class="face-scan-circle">

                <video id="video"
                       autoplay
                       playsinline
                       muted>
                </video>

                <div class="scan-ring"></div>

            </div>

        </div>

        <canvas id="canvas" style="display:none;"></canvas>

        <div id="resultBox" class="biometric-status">
            Initialising camera...
        </div>

    </div>

</div>

<script defer src="https://unpkg.com/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script defer src="~/js/camera-capture.js" asp-append-version="true"></script>